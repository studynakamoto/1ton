{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./build",
    "rootDir": "./",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": ["contracts/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "wrappers/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
