;;
;; Routing of a Contract BondingCurve
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'jettonMaster, $self'treasury, $self'tokenName, $self'realTonReserve, $self'realTokenReserve, $self'graduated) = $BondingCurve$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    int op = 0;
    int in_msg_length = slice_bits(in_msg);
    if (in_msg_length >= 32) {
        op = in_msg~load_uint(32);
    }
    ;; Receive Buy message
    if (op == 1422049996) {
        var $msg'queryId = in_msg~load_uint(64);
        var $msg'minTokensOut = in_msg~load_varuint16();
        throw_unless(55384, (~ $self'graduated));
        var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
        throw_unless(53423, ($ctx'value > 120000000));
        int $tonInGross = ((($ctx'value - 50000000) - 20000000) - 50000000);
        int $fee = (($tonInGross * 100) / 10000);
        int $tonInNet = ($tonInGross - $fee);
        int $vt = (1000000000 + $self'realTonReserve);
        int $vtok = (1000000000000 - $self'realTokenReserve);
        int $k = ($vt * $vtok);
        int $newVt = ($vt + $tonInNet);
        int $newVtok = ($k / $newVt);
        int $tokensOut = ($vtok - $newVtok);
        throw_unless(16529, ($tokensOut > 0));
        throw_unless(48702, ($tokensOut >= $msg'minTokensOut));
        $self'realTonReserve = $self'realTonReserve + $tonInNet;
        $self'realTokenReserve = $self'realTokenReserve + $tokensOut;
        $global_message($MessageParameters$_constructor_to_value_bounce_mode_body($self'jettonMaster, 50000000, true, 1, $Mint$_store_cell($Mint$_constructor_queryId_receiver_tonAmount_mintMessage($msg'queryId, __tact_context_get_sender(), 50000000, $JettonTransferInternal$_constructor_queryId_amount_sender_responseDestination_forwardTonAmount_forwardPayload($msg'queryId, $tokensOut, $self'jettonMaster, __tact_context_get_sender(), 0, $Cell$_fun_beginParse($Builder$_fun_endCell(store_uint($global_beginCell(), 0, 1))))), begin_cell())));
        $global_message($MessageParameters$_constructor_to_value_bounce_mode_body($self'treasury, $fee, false, 1, $TreasuryFee$_store_cell($TreasuryFee$_constructor_queryId_tokenName($msg'queryId, $self'tokenName), begin_cell())));
        if (( (($self'realTonReserve >= 69000000000)) ? ((~ $self'graduated)) : (false) )) {
            $self'graduated = true;
            ($self'jettonMaster, $self'treasury, $self'tokenName, $self'realTonReserve, $self'realTokenReserve, $self'graduated)~$BondingCurve$_fun_initiateGraduation($msg'queryId);
        }
        $BondingCurve$_contract_store(($self'jettonMaster, $self'treasury, $self'tokenName, $self'realTonReserve, $self'realTokenReserve, $self'graduated));
        return ();
    }
    
    ;; Receive JettonNotification message
    if (op == 0x7362d09c) {
        var $msg'queryId = in_msg~load_uint(64);
        var $msg'amount = in_msg~load_varuint16();
        var $msg'sender = in_msg~load_msg_addr();
        var $msg'forwardPayload = in_msg;
        throw_unless(55384, (~ $self'graduated));
        throw_unless(13677, ( equal_slices_bits(__tact_context_get_sender(), ($self'jettonMaster, $self'treasury, $self'tokenName, $self'realTonReserve, $self'realTokenReserve, $self'graduated)~$BondingCurve$_fun_myJettonWallet()) ));
        throw_unless(4737, ($msg'amount > 0));
        int $tokensIn = $msg'amount;
        int $vt = (1000000000 + $self'realTonReserve);
        int $vtok = (1000000000000 - $self'realTokenReserve);
        int $k = ($vt * $vtok);
        int $newVtok = ($vtok + $tokensIn);
        int $newVt = ($k / $newVtok);
        int $tonOutGross = ($vt - $newVt);
        throw_unless(39024, ($tonOutGross > 0));
        throw_unless(7558, ($tonOutGross <= $self'realTonReserve));
        int $minTonOut = 0;
        slice $payload = $msg'forwardPayload;
        if (($Slice$_fun_bits($payload) >= 64)) {
            $minTonOut = $payload~$Slice$_fun_loadCoins();
        }
        int $fee = (($tonOutGross * 100) / 10000);
        int $tonOutNet = ($tonOutGross - $fee);
        throw_unless(48702, ($tonOutNet >= $minTonOut));
        $self'realTonReserve = $self'realTonReserve - $tonOutGross;
        $self'realTokenReserve = $self'realTokenReserve - $tokensIn;
        $global_message($MessageParameters$_constructor_to_value_bounce_mode_body(($self'jettonMaster, $self'treasury, $self'tokenName, $self'realTonReserve, $self'realTokenReserve, $self'graduated)~$BondingCurve$_fun_myJettonWallet(), 30000000, true, 1, $JettonBurn$_store_cell($JettonBurn$_constructor_queryId_amount_responseDestination_customPayload($msg'queryId, $tokensIn, $msg'sender, null()), begin_cell())));
        $global_message($MessageParameters$_constructor_to_value_bounce_mode_body($msg'sender, $tonOutNet, false, 1, $Builder$_fun_endCell(store_uint($global_beginCell(), $msg'queryId, 64))));
        $global_message($MessageParameters$_constructor_to_value_bounce_mode_body($self'treasury, $fee, false, 1, $TreasuryFee$_store_cell($TreasuryFee$_constructor_queryId_tokenName($msg'queryId, $self'tokenName), begin_cell())));
        $BondingCurve$_contract_store(($self'jettonMaster, $self'treasury, $self'tokenName, $self'realTonReserve, $self'realTokenReserve, $self'graduated));
        return ();
    }
    
    ;; Receive empty message
    if ((op == 0) & (in_msg_length <= 32)) {
        $global_cashback(__tact_context_get_sender());
        
        return ();
    }
    ;; Throw if not handled
    throw(130);
}


() __tact_selector_hack_asm() impure asm """
@atend @ 1 {
        execute current@ context@ current!
        {
            // The core idea of this function is to save gas by avoiding unnecessary dict jump, when recv_internal/recv_external is called
            // We want to extract recv_internal/recv_external from the dict and select needed function
            // not by jumping to the needed function by it's index, but by using usual IF statements.

            }END> b> // Close previous builder, now we have a cell of previous code on top of the stack

            <{ // Start of the new code builder
                SETCP0
                // Swap the new code builder with the previous code, now we have previous code on top of the stack
                swap
                // Transform cell to slice and load first ref from the previous code, now we have the dict on top of the stack
                <s ref@

                // Extract the recv_internal from the dict
                dup 0 swap @procdictkeylen idict@ { "internal shortcut error" abort } ifnot
                swap

                // Delete the recv_internal from the dict
                0 swap @procdictkeylen idict- drop
                // Delete the recv_external from the dict (it's okay if it's not there)
                -1 swap @procdictkeylen idict- drop
                // Delete the __tact_selector_hack from the dict
                65535 swap @procdictkeylen idict- drop

                // Bring the code builder from the bottom of the stack
                // because if recv_external extraction is optional, and the number of elements on the stack is not fixed
                depth 1- roll
                // Swap with the dict from which we extracted recv_internal and (maybe) recv_external
                swap

                // Check if the dict is empty
                dup null?
                // Store a copy of this flag in the bottom of the stack
                dup depth 1- -roll
                {
                    // If the dict is empty, just drop it (it will be null if it's empty)
                    drop
                }
                {
                    // If the dict is not empty, prepare continuation to be stored in c3
                    <{
                        // Save this dict as first ref in this continuation, it will be pushed in runtime by DICTPUSHCONST
                        swap @procdictkeylen DICTPUSHCONST
                        // Jump to the needed function by it's index
                        DICTIGETJMPZ
                        // If such key is not found, throw 11 along with the key as an argument
                        11 THROWARG
                    }> PUSHCONT
                    // Store the continuation in c3
                    c3 POP
                } cond

                // Function id is on top of the (runtime) stack
                DUP IFNOTJMP:<{
                    // place recv_internal here
                    DROP swap @addop
                }>

                // Bring back the flag, indicating if the dict is empty or not from the bottom of the stack
                depth 1- roll
                {
                    // If the dict is empty, throw 11
                    11 THROWARG
                }
                {
                    // If the dict is not empty, jump to continuation from c3
                    c3 PUSH JMPX
                } cond
            }> b>
        } : }END>c
        current@ context! current!
    } does @atend !
""";

() __tact_selector_hack() method_id(65535) {
    return __tact_selector_hack_asm();
}