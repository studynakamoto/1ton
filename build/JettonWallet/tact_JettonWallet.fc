        throw_unless(39156, ($ctx'value > ($fwdFee + (2 * $global_getComputeFee(6700, false)))));
        $global_message($MessageParameters$_constructor_to_value_mode_bounce_body($self'minter, 0, 64, true, $JettonBurnNotification$_store_cell($JettonBurnNotification$_constructor_queryId_amount_sender_responseDestination($msg'queryId, $msg'amount, $self'owner, $msg'responseDestination), begin_cell())));
        $JettonWallet$_contract_store(($self'balance, $self'owner, $self'minter));
